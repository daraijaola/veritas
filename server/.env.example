# --- Network ---
SUI_NETWORK=testnet            # mainnet | testnet | devnet
PORT=3001

# --- Tatum (required) ---
# Get a free key at https://dashboard.tatum.io. One key authenticates both the
# Sui RPC gateway and the Tatum Data rate API.
TATUM_SUI_API_KEY=your_tatum_api_key

# --- Sui signer wallet (required) ---
# 12/24-word mnemonic of the server "notary" wallet that signs anchoring txs.
# Use a dedicated wallet with a little SUI for gas.
SUI_WALLET_MNEMONIC="word1 word2 ... word12"

# --- Deployed package (filled in after `npm run deploy:contract`) ---
VERITAS_PACKAGE_ID=

# --- Walrus HTTP endpoints ---
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5
